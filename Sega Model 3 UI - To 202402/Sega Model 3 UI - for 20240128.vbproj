  <Target Name="AfterBuild">
    <ItemGroup>
      <DllFiles Include="$(OutputPath)*.dll" Exclude="$(OutputPath)Sega Model 3 UI for 20240128+.dll" />
    </ItemGroup>
    <MakeDir Directories="$(OutputPath)dll" Condition="!Exists('$(OutputPath)dll')" />
    <Copy SourceFiles="@(DllFiles)" DestinationFolder="$(OutputPath)dll" SkipUnchangedFiles="true" />
    <Delete Files="@(DllFiles)" />
  </Target>
